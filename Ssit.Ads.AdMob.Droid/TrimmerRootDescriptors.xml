<linker>
  <assembly fullname="Ssit.Ads.AdMob.Droid">
    <type fullname="Ssit.Ads.AdMob.Droid.InitListener" preserve="all" />
    <type fullname="Ssit.Ads.AdMob.Droid.LoadCallback" preserve="all" />
    <type fullname="Ssit.Ads.AdMob.Droid.InterstitialCallback" preserve="all" />
    <type fullname="Ssit.Ads.AdMob.Droid.FullScreenCallback" preserve="all" />
  </assembly>
  <!-- Prevent the trimmer from modifying these binding assemblies.
       AOT compiles from the original (aot-in/) versions; if the trimmer changes
       the packaged version, instance sizes diverge and Mono aborts at class-init. -->
  <assembly fullname="Xamarin.GooglePlayServices.Ads.Api" action="copy" />
  <assembly fullname="Xamarin.GooglePlayServices.Ads" action="copy" />
</linker>
